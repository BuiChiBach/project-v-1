expression = "vec2 new_uv = vec2(0.0, 0.5);
bool found = false;

if (color.a > 0.0) {
    for (int i = 0; i < colors_count; i++) {
        float u = (float(i) + 0.5) / float(colors_count);
        vec2 uv = vec2(u, 0.5);
        vec4 original_palette_color = texture(original_palette, uv);
        float dist = distance(color.rgb, original_palette_color.rgb);
        if (dist < 0.01) {
            new_uv = uv;
            found = true;
            break;
        }
    }
}

new_color = found ? texture(new_palette, new_uv) : color;"

